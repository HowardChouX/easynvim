{
  "mcpServers": {
    "tavily": {
      "autoApprove": [
        "tavily_search",
        "tavily_extract",
        "tavily_crawl",
        "tavily_map",
        "tavily_research"
      ],
      "args": [
        "-y",
        "tavily-mcp"
      ],
      "command": "npx",
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "memory": {
      "autoApprove": [
        "create_entities",
        "create_relations",
        "add_observations",
        "delete_entities",
        "delete_observations",
        "delete_relations",
        "read_graph",
        "search_nodes",
        "open_nodes"
      ],
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "command": "npx"
    },
    "filesystem": {
      "autoApprove": [
        "read_file",
        "read_text_file",
        "read_media_file",
        "read_multiple_files",
        "write_file",
        "edit_file",
        "create_directory",
        "list_directory",
        "list_directory_with_sizes",
        "directory_tree",
        "move_file",
        "search_files",
        "get_file_info",
        "list_allowed_directories"
      ],
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/chou/"
      ],
      "command": "npx"
    },
    "git": {
      "autoApprove": [
        "git_status",
        "git_diff_unstaged",
        "git_diff_staged",
        "git_diff",
        "git_commit",
        "git_add",
        "git_reset",
        "git_log",
        "git_create_branch",
        "git_checkout",
        "git_show",
        "git_branch"
      ],
      "args": [
        "mcp-server-git",
        "--repository",
        "/home/chou/.config/nvim/"
      ],
      "command": "uvx",
      "disabled": false
    },
    "time": {
      "autoApprove": [
        "get_current_time",
        "convert_time"
      ],
      "args": [
        "mcp-server-time"
      ],
      "command": "uvx"
    },
    "sequentialthinking": {
      "autoApprove": [
        "sequentialthinking"
      ],
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx"
    },
    "fetch": {
      "autoApprove": [
        "fetch"
      ],
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    }
  }
}